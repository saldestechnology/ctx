# Build artifacts
/target
debug/
release/
*.rs.bk
*.rlib
*.prof*
# Note: Cargo.lock is committed for reproducible builds (this is a binary crate)

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Test/dev files
*.log
tmp/
.env
.env.*

# Generated files (index, embeddings) — but keep the committed project config.
# The rule is repeated with **/ because a leading `.ctx/*` is anchored to the
# repo root and would miss .ctx dirs nested in subdirectories.
.ctx/*
!.ctx/config.toml
**/.ctx/*
!**/.ctx/config.toml
.fastembed_cache/

# AI specific
specs/
.specify
.opencode
.claude

# Release plugin packaging output (scripts/release-plugin-check.sh)
ctx-claude-plugin-*.zip
